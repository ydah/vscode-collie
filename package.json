{
  "name": "collie",
  "displayName": "Collie",
  "description": "Linter and formatter for Lrama Style BNF grammar files",
  "version": "0.1.0",
  "publisher": "ydah",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ydah/vscode-collie.git"
  },
  "bugs": {
    "url": "https://github.com/ydah/vscode-collie/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "preview": true,
  "galleryBanner": {
    "color": "#2b579a",
    "theme": "dark"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Collie does not start external language-server processes until the workspace is trusted.",
      "restrictedConfigurations": [
        "collie.lspPath",
        "collie.configPath",
        "collie.useBundler"
      ]
    }
  },
  "categories": [
    "Linters",
    "Formatters",
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "yacc",
    "bison",
    "lrama",
    "grammar",
    "bnf",
    "parser"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "yacc",
        "aliases": [
          "Yacc",
          "Bison",
          "Lrama"
        ],
        "extensions": [
          ".y",
          ".yacc"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "yacc",
        "scopeName": "source.yacc",
        "path": "./syntaxes/yacc.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "collie.format",
        "title": "Format Document",
        "category": "Collie",
        "enablement": "editorLangId == yacc"
      },
      {
        "command": "collie.lint",
        "title": "Lint Current File",
        "category": "Collie",
        "enablement": "editorLangId == yacc"
      },
      {
        "command": "collie.fixAll",
        "title": "Fix All Auto-correctable Offenses",
        "category": "Collie",
        "enablement": "editorLangId == yacc"
      },
      {
        "command": "collie.restartServer",
        "title": "Restart Language Server",
        "category": "Collie"
      },
      {
        "command": "collie.showOutputChannel",
        "title": "Show Output Channel",
        "category": "Collie"
      },
      {
        "command": "collie.checkSetup",
        "title": "Check Setup",
        "category": "Collie"
      },
      {
        "command": "collie.copyEnvironmentInfo",
        "title": "Copy Environment Info",
        "category": "Collie"
      },
      {
        "command": "collie.createConfig",
        "title": "Create .collie.yml",
        "category": "Collie"
      },
      {
        "command": "collie.openConfig",
        "title": "Open Collie Config",
        "category": "Collie"
      },
      {
        "command": "collie.searchSymbols",
        "title": "Search Symbols",
        "category": "Collie",
        "enablement": "collie.symbolsSupported"
      },
      {
        "command": "collie.previewSyntaxDiagram",
        "title": "Preview Syntax Diagram for Current Rule",
        "category": "Collie",
        "enablement": "editorLangId == yacc && collie.syntaxDiagramSupported"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "collie.fixAll",
          "when": "editorLangId == yacc && collie.fixAllSupported",
          "group": "source"
        },
        {
          "command": "collie.format",
          "when": "editorLangId == yacc && collie.formatSupported",
          "group": "source"
        },
        {
          "command": "collie.previewSyntaxDiagram",
          "when": "editorLangId == yacc && collie.syntaxDiagramSupported",
          "group": "source"
        }
      ],
      "commandPalette": [
        {
          "command": "collie.format",
          "when": "editorLangId == yacc && collie.formatSupported"
        },
        {
          "command": "collie.lint",
          "when": "editorLangId == yacc"
        },
        {
          "command": "collie.fixAll",
          "when": "editorLangId == yacc && collie.fixAllSupported"
        },
        {
          "command": "collie.searchSymbols",
          "when": "collie.symbolsSupported"
        },
        {
          "command": "collie.previewSyntaxDiagram",
          "when": "editorLangId == yacc && collie.syntaxDiagramSupported"
        }
      ]
    },
    "keybindings": [
      {
        "command": "collie.format",
        "key": "shift+alt+f",
        "when": "editorLangId == yacc"
      },
      {
        "command": "collie.fixAll",
        "key": "ctrl+shift+alt+f",
        "mac": "cmd+shift+alt+f",
        "when": "editorLangId == yacc"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Collie",
      "properties": {
        "collie.lspPath": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Path to collie-lsp executable (leave empty to use PATH)"
        },
        "collie.useBundler": {
          "type": "boolean",
          "default": false,
          "description": "Start the language server with bundle exec collie-lsp when no custom path is configured"
        },
        "collie.minimumServerVersion": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Minimum collie-lsp version to accept before showing a warning"
        },
        "collie.enableLinting": {
          "type": "boolean",
          "default": true,
          "description": "Enable linting"
        },
        "collie.enableFormatting": {
          "type": "boolean",
          "default": true,
          "description": "Enable formatting"
        },
        "collie.configPath": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Path to .collie.yml config file"
        },
        "collie.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VSCode and the language server"
        },
        "collie-lsp.serverPath": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "deprecationMessage": "Use collie.lspPath instead.",
          "description": "Deprecated alias for collie.lspPath"
        }
      }
    },
    "configurationDefaults": {
      "[yacc]": {
        "editor.defaultFormatter": "ydah.collie"
      }
    },
    "snippets": [
      {
        "language": "yacc",
        "path": "./snippets/yacc.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run check-types && npm run bundle",
    "bundle": "esbuild src/extension.ts --bundle --external:vscode --format=cjs --platform=node --target=node18 --outfile=out/extension.js --sourcemap --sources-content=false",
    "check-types": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts --max-warnings=0",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "package:smoke": "node ./out/test/packageSmoke.js",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.19.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.45.0",
    "glob": "^10.3.3",
    "mocha": "^10.2.0",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
