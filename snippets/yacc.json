{
  "Token Declaration": {
    "prefix": "token",
    "body": [
      "%token ${1:TOKEN_NAME}"
    ],
    "description": "Declare a token"
  },
  "Token with Type": {
    "prefix": "tokentype",
    "body": [
      "%token <${1:type}> ${2:TOKEN_NAME}"
    ],
    "description": "Declare a token with type tag"
  },
  "Left Associative": {
    "prefix": "left",
    "body": [
      "%left ${1:OPERATOR}"
    ],
    "description": "Left associative operator"
  },
  "Right Associative": {
    "prefix": "right",
    "body": [
      "%right ${1:OPERATOR}"
    ],
    "description": "Right associative operator"
  },
  "Grammar Rule": {
    "prefix": "rule",
    "body": [
      "${1:rule_name}",
      "    : ${2:production}",
      "        { ${3:action} }",
      "    ;"
    ],
    "description": "Grammar rule with action"
  },
  "Alternative": {
    "prefix": "alt",
    "body": [
      "| ${1:production}",
      "    { ${2:action} }"
    ],
    "description": "Rule alternative"
  },
  "Parameterized Rule": {
    "prefix": "prule",
    "body": [
      "%rule ${1:name}(${2:X}, ${3:Y}): ${4:production} ;"
    ],
    "description": "Lrama parameterized rule"
  },
  "Inline Rule": {
    "prefix": "inline",
    "body": [
      "%inline ${1:rule_name}",
      "    : ${2:production}",
      "    ;"
    ],
    "description": "Lrama inline rule"
  },
  "Named Reference": {
    "prefix": "ref",
    "body": [
      "${1:SYMBOL}[${2:name}]"
    ],
    "description": "Lrama named reference"
  }
}
